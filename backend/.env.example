# MongoDB connection string (create a free cluster at https://www.mongodb.com/cloud/atlas)
DB_URL=mongodb+srv://<username>:<password>@<cluster-url>/book-store?retryWrites=true&w=majority

# Secret used to sign admin JWT tokens. Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Port the Express server listens on (optional, defaults to 5000)
PORT=5000
